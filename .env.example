# =====================
# Databricks
# =====================
DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=snaptrash

# =====================
# AWS S3
# =====================
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=snaptrash-bins

# =====================
# External APIs
# =====================
GROQ_API_KEY=
GROQ_VISION_MODEL=llama-4-scout-17b-16e-instruct
FIRECRAWL_API_KEY=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@snaptrash.app
USDA_API_KEY=
MAPBOX_TOKEN=

# =====================
# App
# =====================
ENV=dev
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# =====================
# Vapi + Twilio for Voice Alerts (new apps/voice-alerts/)
# =====================
# Use your existing Vapi account/Assistant (configure system prompt with {{locality}}, {{stats_summary}},
# {{lab_recommendation}} etc. for dynamic reports). PhoneNumberID must support outbound.
# Twilio number/SIP for BYOC if used. Hardcoded alert to +18582146584.
VAPI_API_KEY=sk-...
VAPI_ASSISTANT_ID=ast_...
VAPI_PHONE_NUMBER_ID=pn_...
DEFAULT_ALERT_PHONE=+18582146584
TEST_PHONE_OVERRIDE=  # Set to your number for testing (avoids real calls)

# =====================
# SMTP for Email Alerts (parallel to voice alerts; see EMAIL_CONFIRMATION_SYSTEM.md)
# =====================
# Generate Gmail App Password (16 chars) at https://myaccount.google.com/apppasswords
# Enable 2FA on manasvinsurya.nitt02@gmail.com. Set SMTP_PASS to the App Password.
# ALERT_TO_EMAILS supports comma-separated list (manas + lab mbj@ucsd.edu).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=manasvinsurya.nitt02@gmail.com
SMTP_PASS=your_16char_app_password_here
ALERT_FROM_EMAIL=manasvinsurya.nitt02@gmail.com
ALERT_TO_EMAILS=manasvinsurya.nitt02@gmail.com,mbj@ucsd.edu
