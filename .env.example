# =====================
# Databricks
# =====================
DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=snaptrash

# =====================
# AWS S3
# =====================
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=snaptrash-bins

# =====================
# External APIs
# =====================
GROQ_API_KEY=
GROQ_VISION_MODEL=llama-4-scout-17b-16e-instruct
FIRECRAWL_API_KEY=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@snaptrash.app
USDA_API_KEY=
MAPBOX_TOKEN=

# =====================
# App
# =====================
ENV=dev
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173
